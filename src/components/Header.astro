---
const navItems = [
  { href: '/services/', label: 'Services' },
  { href: '/process/', label: 'Process' },
  { href: '/insights/', label: 'Insights' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="wordmark" href="/" aria-label="Exeme home">
      <img class="brand-logo" src="/exeme_logo.png" alt="Exeme" width="214" height="32" />
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="header-cta" href="/contact/">Book a Growth Audit</a>
  </div>
</header>
